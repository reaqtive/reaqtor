<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>Server-side gRPC adapters for the Reaqtor remoting spike: code-first service implementations (control/Ping; command and broker adapters land with the engine bring-up in Milestone 1) hosted by the Kestrel host exes. See GRPC-REMOTING-SPIKE-PLAN.md §7.</Description>
  </PropertyGroup>

  <ItemGroup>
    <!-- gRPC's public surface (GrpcChannel, CallContext, protobuf-net types, ...) is not CLS-compliant,
         so this assembly cannot be. Opt out of the repo-wide synthesized [assembly: CLSCompliant(true)]
         (Directory.Build.props) and declare it non-CLS-compliant, as the archived Remoting sample did. -->
    <AssemblyAttribute Remove="System.CLSCompliantAttribute" />
    <AssemblyAttribute Include="System.CLSCompliantAttribute">
      <_Parameter1>false</_Parameter1>
      <_Parameter1_TypeName>System.Boolean</_Parameter1_TypeName>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="protobuf-net.Grpc.AspNetCore" />
    <PackageReference Include="Grpc.AspNetCore" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Reaqtor.Remoting.Grpc.Contracts\Reaqtor.Remoting.Grpc.Contracts.csproj" />
    <ProjectReference Include="..\Reaqtor.Remoting.Grpc.Protocol\Reaqtor.Remoting.Grpc.Protocol.csproj" />
    <!-- The MVP host runs the in-host engine (InMemoryReactivePlatform + CoreDeployable + the in-proc command
         bridge); InMemory.Core transitively brings Engine -> Deployable.Core -> Core. -->
    <ProjectReference Include="..\Reaqtor.Remoting.Platform.InMemory.Core\Reaqtor.Remoting.Platform.InMemory.Core.csproj" />
  </ItemGroup>

</Project>
