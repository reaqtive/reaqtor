<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0</TargetFrameworks>
    <Description>Provides a reference implementation of a Reaqtor client library.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\Core\Client\Reaqtor.Client\Reaqtor.Client.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!--
    Until TextTransformCore.exe supports .NET 10, these templates can't execute. They
    needs to reference Reaqtive.Interfaces, Reaqtive.Core, and Reaqtive.Linq, and
    we can't build those for .NET 8.0 without effectively downgrading everything.
    For the time being, nothing needs to change in the generated code, so we can
    just continue to use the last generator output from back when we ran on
    .NET FX, but we will want to reinstate this when possible.
    (An alternative would be to move off T4.)
    -->
    <TextTemplates Remove="ClientContext.Generated.tt" />
    <TextTemplates Remove="QueryOperators.Generated.tt" />
  </ItemGroup>

</Project>
