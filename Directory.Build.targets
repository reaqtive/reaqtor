<Project>

  <!--
  This is a workaround for problems caused by https://github.com/dotnet/roslyn/issues/41640
  -->
  <PropertyGroup Condition="'$(GenerateDocumentationFile)' == 'false'">
    <NoWarn>$(NoWarn);IDE0005</NoWarn>
  </PropertyGroup>

  <!--
  VS introduced support for running T4 templates with modern .NET runtimes in Visual Studio 2022 v17.6.
  However, the IDE integration (enabled by <Service Include="{508349b6-6b84-4df5-91f0-309beebad82d}" />)
  continues only to support .NET FX as far as I can tell. We are therefore no longer using that
  mechanism, and instead invoke the TextTransformCore.exe tool directly in a pre-build step. This
  Target is set up to run the transform only when the template is newer than the output file, or
  the output file does not yet exist. This is actually an improvement on the old built-in tooling
  because it avoids the .tt and generated .cs files getting out of sync. (That actually happened
  once due to a global modification done by a code analyzer that didn't understand that it was
  modifying a generated file. This new approach makes it harder for that kind of mistake to slip
  though unnoticed.)
  
  Note that the test for $(DevEnvDir) prevents errors when running dotnet build from a command line
  that does not have the Visual Studio environment variables set. In that case, the T4 templates
  will not be executed. Since we check generated files into source control, this is acceptable
  because everything will build. It just means that if you want to modify a template, you
  will need to build from Visual Studio (or a VS-aware environment) to regenerate the output files.
  -->
  <Target
    Name="_TransformTextTemplates"
    BeforeTargets="PreBuildEvent"
    Condition="@(TextTemplates) != '' and $(DevEnvDir) != ''"
    Inputs="@(TextTemplates)"
    Outputs="@(TextTemplates->'%(GeneratedOutputRelativePath)')">

    <Exec
      WorkingDirectory="$(ProjectDir)"
      Command='"$(DevEnvDir)TextTransformCore.exe" "%(TextTemplates.Identity)"' />

  </Target>
  
  <!--
  This ensures that the files generated by T4 templates appear nested inside their .tt files in
  Solution Explorer.
  -->
  <ItemGroup>
    <Compile Update="@(TextTemplates->'%(GeneratedOutputRelativePath)')">
      <DesignTime>true</DesignTime>
      <AutoGen>true</AutoGen>
      <DependentUpon>%(TextTemplates.Filename).tt</DependentUpon>
    </Compile>
  </ItemGroup>

</Project>
