<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>Provides a virtualization layer for reflection.</Description>
    <!--
      This library faithfully mirrors System.Reflection, including members that became obsolete on
      modern .NET (Type.IsSerializable, FieldAttributes.NotSerialized, Assembly.LoadFrom with a hash
      algorithm). The mirrors still function on .NET 10, so the obsoletion diagnostics are suppressed.
    -->
    <NoWarn>$(NoWarn);SYSLIB0050;SYSLIB0056</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Nuqleon.Memory\Nuqleon.Memory.csproj" />
  </ItemGroup>

</Project>
